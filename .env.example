# Copy to .env and fill in ONE backend for harness mode (optional for Cursor skill mode)

# OpenAI (use with model_openai.yaml)
# OPENAI_API_KEY=sk-...

# Anthropic (use with model_claude.yaml)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (use with model_openrouter.yaml if configured)
# OPENROUTER_API_KEY=sk-or-...
